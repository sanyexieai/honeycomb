# Core identity
HC_TENANT_ID=local
HC_USER_ID=default

# LLM provider selection
HC_LLM_PROVIDER=minimax
HC_LLM_MODEL=MiniMax-M2.5

# Preferred generic API key variable
HC_LLM_API_KEY=
# Or use a provider-specific variable instead
# MINIMAX_API_KEY=
# OPENAI_API_KEY=

# Optional MiniMax-compatible endpoint override
# HC_LLM_BASE_URL=https://api.minimaxi.com/v1
# MINIMAX_BASE_URL=https://api.minimaxi.com/v1

# Context pipeline strategy
# auto: try LLM first, then fall back to rules when unavailable
# llm: require LLM
# rule: never call LLM for these steps
HC_CONTEXT_ORGANIZER_MODE=auto
HC_CONTEXT_PROMPT_ASSET_MODE=auto
HC_CONTEXT_PREFERENCE_SUMMARY_MODE=auto
HC_CONTEXT_PROMOTION_TRIGGER=window_full
HC_CONTEXT_PROMOTION_WINDOW_SIZE=8
HC_CONTEXT_LITERARY_TRIGGER=window_full
HC_CONTEXT_LITERARY_WINDOW_SIZE=4
HC_CONTEXT_CHAT_ROOM_WINDOW_SIZE=12

# Optional behavior toggles
HC_CONTEXT_CHAT_MEMORY=true
HC_CONTEXT_LITERARY_MEMORY=true
HC_LLM_REQUEST_MODE=direct

# After a scheduled target of kind `agent` succeeds, optionally run conversation inbox
# processing so events become agent turn proposals (no LLM until you draft explicitly).
# HC_SCHEDULE_AGENT_AUTO_PROCESS_INBOX=1

# Scheduler followup delivery strategy used by hc-api scheduler loop / dispatch endpoints:
# headless (default) | off | webhook
# HC_SCHEDULER_FOLLOWUP_DELIVERY_MODE=headless
# When webhook: set HTTPS URL; each fired follow-up posts JSON { tenant_id, user_id, followup_id, message }.
# HC_SCHEDULER_FOLLOWUP_WEBHOOK_URL=https://example.com/honeycomb/followup
# Optional: HC_SCHEDULER_FOLLOWUP_WEBHOOK_BEARER_TOKEN=…
# Optional: HC_SCHEDULER_FOLLOWUP_WEBHOOK_TIMEOUT_SECS=30

# Timed reminder / countdown mirror tasks (ScheduledTask target timed.followup): max retries and
# backoff when dispatch fails (persist path only; unset = defaults from SchedulePolicy).
# HC_TIMED_FOLLOWUP_SCHEDULE_MAX_RETRIES=3
# HC_TIMED_FOLLOWUP_SCHEDULE_RETRY_DELAY_SECONDS=60

# hc-cli chat: periodic dispatch for timed follow-ups (mirror + stdout `assistant>`), same primitives as schedule watch.
# Default: ticker on. Use 0 | false | no | off only when running `hc-cli schedule watch` for the same tenant/user.
# HC_CLI_CHAT_SCHEDULER_ENABLED=false
# HC_CLI_CHAT_SCHEDULER_TICK_MS=500

# HTTP L2/L3: optional workbench-like planner JSON steering into task_plan.md before excerpt (extra LLM call).
# HC_HTTP_CHAT_L2L3_PLANNER_STEER=1

# ADR-006 stub: allow experience-lane features when task has enable_learning (future wiring).
# HC_TENANT_LEARNING_ALLOWED=1