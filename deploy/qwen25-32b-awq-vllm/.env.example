# Copy to .env and adjust:
#   cp .env.example .env

VLLM_PORT=8000

# Context length cap (lower = less KV VRAM). If OOM, try 8192 or 4096.
MAX_MODEL_LEN=16384

# Fraction of GPU memory vLLM may use (0.0–1.0).
GPU_MEMORY_UTILIZATION=0.92

# Max concurrent sequences; lower if OOM under load.
MAX_NUM_SEQS=8

# Optional Hugging Face token (not required for Qwen/Qwen2.5-32B-Instruct-AWQ).
# HF_TOKEN=
